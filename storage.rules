rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /products/{allPaths=**} {
      // Allow public read access to product images
      allow read: if true;
      // Allow write access only to authenticated users (optionally check for admin role in firestore if needed)
      // For now, allow any authenticated user to upload images to this specific path
      allow write: if request.auth != null;
    }
    
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
