{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Customer and Admin profiles",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "wishlist": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Electronics inventory item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "videoUrl": { "type": "string" },
        "stock": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "featured": { "type": "boolean" }
      },
      "required": ["id", "name", "price", "category", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Simplified WhatsApp-bound order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "delivering", "delivered"] },
        "deliveryAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review and rating",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating"]
    },
    "AdminConfig": {
      "title": "Admin Configuration",
      "description": "System-wide admin settings",
      "type": "object",
      "properties": {
        "pin": { "type": "string" },
        "allowedEmails": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "Whitelist of up to 5 admin emails"
        }
      },
      "required": ["pin"]
    }
  },
  "firestore": {
    "/products/{productId}": { "schema": "Product", "description": "Inventory management" },
    "/orders/{orderId}": { "schema": "Order", "description": "Sales and tracking" },
    "/reviews/{reviewId}": { "schema": "Review", "description": "Customer feedback" },
    "/system/admin": { "schema": "AdminConfig", "description": "Admin access control" }
  }
}
