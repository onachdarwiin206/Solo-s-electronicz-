{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile information and role.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "staff", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Electronic devices available for sale.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["Phones", "Computers", "Electronics"] },
        "image": { "type": "string" },
        "stock": { "type": "integer" },
        "featured": { "type": "boolean" }
      },
      "required": ["name", "price", "category", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase records.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "deliveryAddress": { "type": "string" },
        "receiptId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "deliveryAddress", "receiptId"]
    },
    "MarketingPost": {
      "title": "Marketing Post",
      "description": "Posts created by staff for marketing.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "staffId": { "type": "string" },
        "staffName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "staffId", "staffName"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles."
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Stores product information."
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Stores customer orders."
    },
    "marketing_posts/{postId}": {
      "schema": "MarketingPost",
      "description": "Stores marketing material."
    }
  }
}
