rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isStaff() {
      return isSignedIn() && (getUserData().role == 'staff' || getUserData().role == 'admin');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Orders
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isStaff());
      allow update: if isStaff() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    // Marketing Posts
    match /marketing_posts/{postId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Connection test document
    match /test/connection {
      allow read: if true;
    }
  }
}
