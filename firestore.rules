rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Primary check: document role
      // Secondary check for bootstrapping: literal email
      return isSignedIn() && (
        (request.auth.token.email == 'onachdarwiin@gmail.com' && request.auth.token.email_verified == true) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // USER PROFILES
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && isValidId(userId) &&
        (incoming().role == 'customer' || (incoming().role == 'admin' && isAdmin())) &&
        incoming().name is string && incoming().name.size() <= 100;
      allow update: if (isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'district', 'address', 'wishlist', 'likes', 'lastLogin'])
      )) || isAdmin();
    }

    // INVENTORY
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ORDERS
    match /orders/{orderId} {
      // allow get: if true; is acceptable for a tracking feature where ID is the shared secret.
      // However, we should still ensure it's a valid ID format.
      allow get: if isValidId(orderId);
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if (
          ((isSignedIn() && incoming().userId == request.auth.uid) || incoming().userId == 'guest') &&
          incoming().items is list && incoming().items.size() > 0 &&
          incoming().total is number &&
          incoming().status == 'pending'
        );
      allow update: if isAdmin() && (
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
        );
      allow delete: if false;
    }

    // REVIEWS
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if incoming().userId == 'guest' &&
        incoming().rating >= 1 && incoming().rating <= 5 &&
        incoming().comment is string && incoming().comment.size() <= 1000;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // SYSTEM
    match /system/admin {
      allow read: if true; // Needed for client-side PIN verification
      allow write: if false; // Only manual via console
    }
  }
}
