rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'role']) &&
             data.id == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['customer', 'staff', 'admin'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'image']) &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.category in ['Phones', 'Computers', 'Electronics'] &&
             data.image is string && data.image.size() <= 1000;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status', 'deliveryAddress', 'receiptId']) &&
             data.userId == request.auth.uid &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.status in ['Pending', 'Confirmed', 'Paid', 'Packing', 'Out for Delivery', 'Delivered', 'Cancelled'] &&
             data.deliveryAddress is string && data.deliveryAddress.size() <= 500 &&
             data.receiptId is string && data.receiptId.size() <= 100;
    }

    // --- Collection Matches ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidUser(incoming()) && incoming().role == 'customer';
      allow update: if (isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'district', 'address', 'wishlist', 'likes'])
      )) || isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidProduct(incoming());
      
      // Allow customers to like/view stock updates implicitly via read
      // But formal likes count updates would ideally happen via a batch or higher security
      allow update: if (isSignedIn() && !isAdmin() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']) &&
        incoming().likesCount == (existing().get('likesCount', 0) + 1 || existing().get('likesCount', 0) - 1)
      );
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isAdmin(); // Only admins can update order status
    }

    match /marketing_posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
